{
  "name": "Weekly GitHub Activity Summary",
  "nodes": [
    {
      "name": "Weekly Cron Trigger",
      "type": "n8n-nodes-base.cron",
      "parameters": {
        "triggerTimes": {
          "item": [{"mode": "everyWeek", "hour": 17, "minute": 0, "weekday": 5}]
        }
      }
    },
    {
      "name": "GitHub Commits",
      "type": "n8n-nodes-base.github",
      "parameters": {
        "owner": "={{ $json.owner }}",
        "repo": "={{ $json.repo }}",
        "resource": "issue",
        "operation": "get",
        "additionalFields": {}
      }
    },
    {
      "name": "Claude API Generate Summary",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "x-api-key", "value": "={{ $credentials.claudeApiKey }}"},
            {"name": "anthropic-version", "value": "2023-06-01"},
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "model", "value": "claude-sonnet-4-20250514"},
            {"name": "max_tokens", "value": 4096},
            {"name": "messages", "value": "[{\"role\": \"user\", \"content\": \"Generate a weekly development summary based on these activities: {{ $json.activities }}\"}]"}
          ]
        }
      }
    },
    {
      "name": "Send Email Summary",
      "type": "n8n-nodes-base.emailSend",
      "parameters": {
        "fromEmail": "syntaxhq.dev@gmail.com",
        "toEmail": "syntaxhq.dev@gmail.com",
        "subject": "Weekly Development Summary",
        "text": "={{ $json.content }}"
      }
    }
  ],
  "connections": {
    "Weekly Cron Trigger": {"main": [[{"node": "GitHub Commits"}]]},
    "GitHub Commits": {"main": [[{"node": "Claude API Generate Summary"}]]},
    "Claude API Generate Summary": {"main": [[{"node": "Send Email Summary"}]]}
  }
}
